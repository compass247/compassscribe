# Frontend (Next.js) runtime config. Copy to .env.local for local dev.
# NEXT_PUBLIC_* values are exposed to the browser.

# Lead form API base (empty = same-origin /api). In prod: https://api.compassagewell.com
NEXT_PUBLIC_API_BASE=

# Directus CMS origin for reading published content.
# Local: http://localhost:8055   Prod: https://cms.compassagewell.com
NEXT_PUBLIC_CMS_BASE=http://localhost:8055

# Canonical site URL (used for SEO metadata, sitemap, hreflang).
NEXT_PUBLIC_SITE_URL=https://compassagewell.com

# Shared secret for the Directus Flow -> /api/revalidate webhook (publish=live).
# Must match REVALIDATE_SECRET in Secrets Manager / backend/cms/.env.
REVALIDATE_SECRET=local-revalidate-secret-change-me
