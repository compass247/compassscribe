# Copy this file to backend/cms/.env and fill in real values.
# In production these come from AWS Secrets Manager (see infra/cms-secrets.tf),
# NEVER committed. This file documents every variable the CMS stack needs.

# --- Postgres ---
DB_PASSWORD=directus

# --- Directus security keys ---
# Generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DIRECTUS_KEY=local-dev-key-change-me
DIRECTUS_SECRET=local-dev-secret-change-me

# --- First-run admin (bootstrap account; change password after first login) ---
ADMIN_EMAIL=admin@compassagewell.com
ADMIN_PASSWORD=changeme-locally

# --- URLs / CORS ---
# Local: Directus on :8055, Next.js frontend on :3000.
PUBLIC_URL=http://localhost:8055
CORS_ORIGIN=http://localhost:3000

# --- Revalidation webhook (Phase 2) ---
# Shared secret the Directus Flow uses to call the Next.js /api/revalidate route.
REVALIDATE_SECRET=local-revalidate-secret-change-me
